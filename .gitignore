# ---------------------------------------------------------
# Общие правила игнорирования для репозитория студента
# ---------------------------------------------------------

# Системные файлы ОС
.DS_Store
Thumbs.db

# Конфигурации IDE/редакторов
.vscode/
.idea/
*.swp
*.swo

# Виртуальные окружения Python
.venv/
venv/
env/
ENV/
.conda/

# Кеши Python и скомпилированные файлы
__pycache__/
*.py[cod]
*$py.class

# Папки и файлы сборки/дистрибуции
build/
dist/
eggs/
*.egg-info/
.installed.cfg
ya_prof/

# Кеши и артефакты тестов
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Журналы
*.log
logs/
data/

# Кеши Jupyter Notebook
.ipynb_checkpoints

# Файлы окружения и конфигурации с потенциальными секретами
.env
*.env
.env.*
!.env.example

# UV (package manager)
uv.lock
reports_example/

# ML артефакты (модели НЕ коммитим!)
*.joblib
*.pkl
models/

# Разное
*.tmp
*.bak
*.old
